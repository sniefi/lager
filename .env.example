# Datenbankverbindung (für lokale Entwicklung mit docker-compose)
DATABASE_URL=mysql+pymysql://lager:lagerpassword@db:3306/lager

# Zufälliger langer String – in Coolify generieren
SECRET_KEY=change-this-to-a-long-random-string

# bcrypt-Hash des App-Passworts
# Generieren mit: python -c "import bcrypt; print(bcrypt.hashpw(b'deinPasswort', bcrypt.gensalt()).decode())"
APP_PASSWORD_HASH=$2b$12$examplehashchangethis

# Nur für lokale Entwicklung mit docker-compose nötig
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_PASSWORD=lagerpassword
